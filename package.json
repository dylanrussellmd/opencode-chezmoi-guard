{
  "name": "@dylanrussell/chezmoi-guard",
  "version": "1.1.1",
  "description": "Redirect opencode agent edits to chezmoi source files, then sync. Intercepts edit/write/apply_patch so agents never edit chezmoi-managed targets out-of-band.",
  "license": "MIT",
  "author": "Dylan Russell",
  "type": "module",
  "main": "./dist/plugin.js",
  "module": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/dylanrussellmd/opencode-chezmoi-guard#readme",
  "bugs": "https://github.com/dylanrussellmd/opencode-chezmoi-guard/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dylanrussellmd/opencode-chezmoi-guard.git"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "test": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest",
    "version": "node scripts/sync-version.mjs && git add src/version.ts",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run build && npm run test"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.14.0"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@opencode-ai/plugin": "^1.17.15",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "chezmoi",
    "dotfiles",
    "file-manager",
    "guard"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "overrides": {
      "uuid": ">=14.0.0",
      "vite": ">=6.4.2",
      "esbuild": ">=0.25.0"
    }
  }
}
